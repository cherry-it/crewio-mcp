# Local dev only — Docker sets NODE_ENV=production automatically
NODE_ENV=development
PORT=3002

# URL of your crewio-backend instance
CREWIO_API_URL=http://localhost:3000

# OpenAI — required for the AI agent (/chat endpoint)
OPENAI_API_KEY=sk-...

# Agent tuning (all optional — defaults shown)
AGENT_MODEL=gpt-4.1
AGENT_MAX_TURNS=10

# Langfuse tracing (optional) — set BOTH keys to enable tracing.
# Find them in Langfuse → Settings → API Keys. When unset, tracing is disabled.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
# EU: https://cloud.langfuse.com · US: https://us.cloud.langfuse.com · or self-hosted
LANGFUSE_BASE_URL=https://cloud.langfuse.com
