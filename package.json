{
  "name": "crewio-agent",
  "version": "0.2.0",
  "description": "AI agent + MCP server for Crewio — chat interface and CRM tools for AI assistants",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepare": "husky"
  },
  "dependencies": {
    "@langfuse/otel": "^5.7.0",
    "@langfuse/tracing": "^5.7.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@openai/agents": "^0.12.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "fastify": "^5.8.5",
    "openai": "^6.45.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "*.ts": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.{json,md,yml,yaml}": [
      "oxfmt"
    ]
  },
  "engines": {
    "node": ">=22"
  }
}
